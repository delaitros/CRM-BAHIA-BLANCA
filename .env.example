# ============================================================
# Lo de Juan - CRM Bahía Blanca
# Copiar este archivo a .env y completar los valores
# cp .env.example .env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=chatwoot
POSTGRES_PASSWORD=CAMBIAR_password_seguro_aqui

# ── Chatwoot ────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
SECRET_KEY_BASE=CAMBIAR_generar_con_openssl_rand_hex_64
CHATWOOT_URL=http://localhost:3000
CHATWOOT_PORT=3000

# Chatwoot API (obtener desde Chatwoot > Settings > Account > API)
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# ── Facebook / Instagram / WhatsApp ────────────────────────
# Configurar en Meta Business Suite > Developers
FB_APP_ID=
FB_APP_SECRET=
FB_VERIFY_TOKEN=
IG_VERIFY_TOKEN=

# ── n8n ─────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_password_n8n_aqui
# Generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CAMBIAR_generar_con_openssl_rand_hex_32

# ── IA (elegir uno o ambos) ─────────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Anthropic (Claude): https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Calendar (para verificar disponibilidad) ─────────
# Crear en Google Cloud Console > APIs > Calendar API
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Email (SMTP - opcional) ─────────────────────────────────
MAILER_SENDER_EMAIL=noreply@lodejuan.com
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# ── Web ─────────────────────────────────────────────────────
WEB_PORT=80
