    "Preparar Contexto": {
      "main": [
        [
          {
            "node": "Agente IA (Claude)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Agente IA (Claude)": {
      "main": [
        [
          {
            "node": "Verificar Acciones Especiales",
            "type": "main",
            "index": 0
          },
          {
            "node": "Derivar a Humano?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Verificar Acciones Especiales": {
      "main": [
        [
          {
            "node": "Consultar Google Calendar",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Enviar Respuesta a Chatwoot",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Consultar Google Calendar": {
      "main": [
        [
          {
            "node": "Enviar Respuesta a Chatwoot",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Derivar a Humano?": {
